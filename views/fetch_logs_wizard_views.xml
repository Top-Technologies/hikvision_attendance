<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_fetch_logs_wizard_form" model="ir.ui.view">
        <field name="name">hikvision.fetch.logs.wizard.form</field>
        <field name="model">hikvision.fetch.logs.wizard</field>
        <field name="arch" type="xml">
            <form string="Fetch Logs">
                <group>
                    <field name="device_id" invisible="context.get('hide_device', False)" options="{'no_create': True}"/>
                    <field name="date_range" widget="radio"/>
                </group>
                <group invisible="date_range != 'custom'">
                    <group>
                        <field name="start_date" required="date_range == 'custom'"/>
                    </group>
                    <group>
                        <field name="end_date" required="date_range == 'custom'"/>
                    </group>
                </group>
                <group invisible="date_range == 'custom'">
                    <group>
                        <field name="start_date" readonly="1"/>
                    </group>
                    <group>
                        <field name="end_date" readonly="1"/>
                    </group>
                </group>
                <group string="Advanced Options" invisible="1">
                    <field name="use_chunking" invisible="1"/>
                    <field name="chunk_days" invisible="1"/>
                </group>
                <div class="alert alert-info" role="alert" invisible="1">
                    <strong>Chunked Fetching Enabled:</strong> Large date ranges will be split into smaller chunks to prevent authentication errors and ensure complete data retrieval.
                </div>
                <footer>
                    <button name="action_fetch_logs" string="Fetch Logs" type="object" class="btn-primary"/>
                    <button string="Cancel" class="btn-secondary" special="cancel"/>
                </footer>
            </form>
        </field>
    </record>

    <!-- Global Fetch Records Action -->
    <record id="action_fetch_attendance_wizard" model="ir.actions.act_window">
        <field name="name">Fetch Records</field>
        <field name="res_model">hikvision.fetch.logs.wizard</field>
        <field name="view_mode">form</field>
        <field name="target">new</field>
    </record>
</odoo>
