<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_employee_form_inherit_hikvision" model="ir.ui.view">
        <field name="name">hr.employee.form.inherit.hikvision</field>
        <field name="model">hr.employee</field>
        <field name="inherit_id" ref="hr.view_employee_form"/>
        <field name="arch" type="xml">
            <xpath expr="//page[@name='hr_settings']" position="inside">
                <group string="Hikvision Attendance" name="hikvision_attendance">
                    <field name="attendance_policy_id"/>
                    <field name="department_id" readonly="1"/>
                </group>
            </xpath>
        </field>
    </record>
</odoo>
