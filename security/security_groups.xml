<?xml version="1.0" encoding="UTF-8"?>
<odoo>
    <!-- Security Category -->
    <record id="module_category_hikvision" model="ir.module.category">
        <field name="name">Hikvision Attendance</field>
        <field name="description">Access rights for Hikvision Attendance module</field>
        <field name="sequence">50</field>
    </record>

    <!-- User Group (Read Only) -->
    <record id="group_hikvision_user" model="res.groups">
        <field name="name">User</field>
        <field name="category_id" ref="module_category_hikvision"/>
        <field name="comment">Can view attendance records but cannot edit.</field>
    </record>

    <!-- HR Manager Group (Limited Edit) -->
    <record id="group_hikvision_hr" model="res.groups">
        <field name="name">HR Manager</field>
        <field name="category_id" ref="module_category_hikvision"/>
        <field name="implied_ids" eval="[(4, ref('group_hikvision_user'))]"/>
        <field name="comment">Can view and manage attendance records. Can sync with devices.</field>
    </record>

    <!-- Admin Group (Full Access) -->
    <record id="group_hikvision_admin" model="res.groups">
        <field name="name">Administrator</field>
        <field name="category_id" ref="module_category_hikvision"/>
        <field name="implied_ids" eval="[(4, ref('group_hikvision_hr'))]"/>
        <field name="comment">Full access to all Hikvision features including editing attendance and managing devices.</field>
        <field name="users" eval="[(4, ref('base.user_root')), (4, ref('base.user_admin'))]"/>
    </record>
</odoo>
